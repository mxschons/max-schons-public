# Local-only variable map for content files.
#
# Copy this file to `.env` (gitignored) and fill in real values.
# Anywhere a repo file contains `${VARNAME}`, an AI workflow running locally
# can resolve it by reading `.env`. Public visitors just see the token.
#
# Variables currently referenced in the repo:

BANK_TAX_DEDUCTIBLE=
BANK_GENERAL=
BANK_INTERNATIONAL=
BANK_DEPRECATED=
BROKER=
HARDWARE_WALLET=
HEALTH_INSURANCE=
PENSION_PROVIDER=
PROFESSIONAL_LIABILITY_INSURANCE=
PRIVATE_LIABILITY_INSURANCE=
VPN=
DNS=
EMAIL_PROVIDER=
SCAN_SERVICE=
DOMAIN_REGISTRAR=
